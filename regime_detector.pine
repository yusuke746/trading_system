//@version=6
indicator("Regime Detector [1H/15M]", overlay=true, max_labels_count=500)

// ─── Parameters ───────────────────────────────────────────────────────────────
adx_trend_min     = input.int(25,    "ADXトレンド閾値",        minval=10, maxval=50)
adx_range_max     = input.int(20,    "ADXレンジ閾値",          minval=5,  maxval=30)
adx_reversal_drop = input.int(5,     "ADX低下幅（REVERSAL）",  minval=1,  maxval=15)
adx_period        = input.int(14,    "ADX期間",                minval=5,  maxval=30)
ema_period        = input.int(21,    "EMA期間",                minval=5,  maxval=50)
atr_breakout_mult = input.float(1.5, "ATRブレイク倍率",         minval=1.0, maxval=3.0, step=0.1)
atr_period        = input.int(14,    "ATR期間",                minval=5,  maxval=30)
range_lookback    = input.int(10,    "レンジ判定バー数",         minval=5,  maxval=20)
show_labels       = input.bool(true, "レジームラベル表示")
show_debug        = input.bool(true, "デバッグ情報表示")

// ─── Manual ADX (DMI ベース) ──────────────────────────────────────────────────
// ta.adx はバージョンによって挙動が異なるため、+DI/-DI から自前で計算する
adx_calc(h, l, c, period) =>
    up       = ta.change(h)
    down     = -ta.change(l)
    plus_dm  = (up > down and up > 0) ? up : 0.0
    minus_dm = (down > up and down > 0) ? down : 0.0
    tr       = math.max(math.max(h - l, math.abs(h - nz(c[1], c))), math.abs(l - nz(c[1], c)))
    atr_s    = ta.rma(tr, period)
    plus_di  = atr_s != 0 ? 100.0 * ta.rma(plus_dm,  period) / atr_s : 0.0
    minus_di = atr_s != 0 ? 100.0 * ta.rma(minus_dm, period) / atr_s : 0.0
    di_sum   = plus_di + minus_di
    dx       = di_sum != 0 ? 100.0 * math.abs(plus_di - minus_di) / di_sum : 0.0
    ta.rma(dx, period)

// ─── 1H 大局フィルター ─────────────────────────────────────────────────────────
// barmerge.lookahead_off で未来参照を防ぐ
[h1_close, h1_high, h1_low] = request.security(
     syminfo.tickerid, "60", [close, high, low],
     lookahead=barmerge.lookahead_off)

h1_adx = request.security(
     syminfo.tickerid, "60",
     adx_calc(high, low, close, adx_period),
     lookahead=barmerge.lookahead_off)

h1_ema = request.security(
     syminfo.tickerid, "60",
     ta.ema(close, ema_period),
     lookahead=barmerge.lookahead_off)

// 1H 判定
h1_adx_valid   = h1_adx >= adx_trend_min
h1_direction   = h1_close > h1_ema ? "bull" : "bear"
h1_trend_valid = h1_adx_valid

// ─── 15M 計算 ─────────────────────────────────────────────────────────────────
m15_adx      = adx_calc(high, low, close, adx_period)
m15_ema      = ta.ema(close, ema_period)
m15_atr      = ta.atr(atr_period)
m15_atr_ma20 = ta.sma(m15_atr, 20)
m15_adx_avg5 = ta.sma(m15_adx, 5)            // REVERSALのADX低下判定に使用

// レンジ高値・安値（BREAKOUTの方向判定に使用）
range_high = ta.highest(high[1], range_lookback)
range_low  = ta.lowest(low[1],  range_lookback)

// 直近 range_lookback 本の ADX 平均（BREAKOUTの「直前がレンジだったか」判定）
adx_avg_lookback = ta.sma(m15_adx, range_lookback)

// ─── レジーム判定 ──────────────────────────────────────────────────────────────
var string regime    = "RANGE"
var string direction = "none"

// 1位: REVERSAL
//   条件1: 15M ADX >= adx_trend_min（ある程度トレンドが出ている）
//   条件2: 15M ADX < (直近5本平均 - adx_reversal_drop)（ADXが低下中）
is_reversal = m15_adx >= adx_trend_min and
              m15_adx < (m15_adx_avg5 - adx_reversal_drop)

// 2位: BREAKOUT
//   条件1: ATR がMA20の倍率を超えている（ボラ急拡大）
//   条件2: 直前 range_lookback 本の ADX平均 < adx_range_max（直前がレンジだった）
//   条件3: 現在ADX >= adx_range_max（今はレンジでない）
is_breakout = m15_atr > m15_atr_ma20 * atr_breakout_mult and
              adx_avg_lookback < adx_range_max and
              m15_adx >= adx_range_max

// 3位: TREND
//   条件1: 15M ADX >= adx_trend_min
//   条件2: 1H トレンド有効
//   条件3: 15M close/EMAの位置が 1H 方向と一致
trend_align = (h1_direction == "bull" and close > m15_ema) or
              (h1_direction == "bear" and close < m15_ema)
is_trend    = m15_adx >= adx_trend_min and h1_trend_valid and trend_align

// 優先順位変更: v4.1 TREND(1位) > BREAKOUT(2位) > REVERSAL(3位) > RANGE(4位)
string new_regime = "RANGE"
if is_trend
    new_regime := "TREND"
else if is_breakout
    new_regime := "BREAKOUT"
else if is_reversal
    new_regime := "REVERSAL"

// ─── 方向決定 ─────────────────────────────────────────────────────────────────
// REVERSAL: 1H方向の逆（トレンド転換を狙う）
string rev_direction = h1_direction == "bull" ? "sell" : "buy"

// BREAKOUT: レンジをどちらに抜けたかで決定
string bo_direction = close > range_high ? "buy" :
                      close < range_low  ? "sell" : "none"

// TREND: 1H方向と15M EMA位置が一致するとき
string trend_direction = h1_direction == "bull" and close > m15_ema ? "buy" :
                         h1_direction == "bear" and close < m15_ema ? "sell" : "none"

string new_direction = new_regime == "REVERSAL" ? rev_direction   :
                       new_regime == "BREAKOUT"  ? bo_direction    :
                       new_regime == "TREND"     ? trend_direction :
                       "none"

// レジーム変化検知（ラベル表示のトリガー）
bool regime_changed = new_regime != regime

// 状態更新（var変数に書き戻す）
regime    := new_regime
direction := new_direction

// ─── ラベル表示 ────────────────────────────────────────────────────────────────
// レジームが変わったバーにのみ表示する（毎バー出すと max_labels_count を超える）
if show_labels and regime_changed
    float  label_y = high + m15_atr * 0.5
    string lbl_txt = regime == "TREND" ? (direction == "buy" ? "T↑" : "T↓") : regime == "REVERSAL" ? (direction == "buy" ? "R↑" : "R↓") : regime == "BREAKOUT" ? (direction == "buy" ? "B↑" : "B↓") : "RNG"
    color  lbl_col = regime == "TREND" ? color.green : regime == "REVERSAL" ? color.red : regime == "BREAKOUT" ? color.blue : color.gray
    label.new(bar_index, label_y, lbl_txt, color=lbl_col, textcolor=color.white, style=label.style_label_down, size=size.small)

// ─── デバッグテーブル ───────────────────────────────────────────────────────────
if show_debug
    var table t = table.new(position.bottom_right, 2, 7, bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1, frame_color=color.gray, frame_width=1)

    // ADX drop: 5本平均との差（正 = ADX低下中）
    float adx_drop_val = m15_adx_avg5 - m15_adx
    // ATR倍率: 現在ATR ÷ ATR MA20
    float atr_mult_val = m15_atr_ma20 > 0 ? m15_atr / m15_atr_ma20 : 0.0

    color regime_col = regime == "TREND"    ? color.green :
                       regime == "REVERSAL" ? color.red   :
                       regime == "BREAKOUT" ? color.blue  :
                       color.gray

    table.cell(t, 0, 0, "1H ADX",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 0, str.tostring(h1_adx, "#.#"),
               text_color = color.yellow,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 1, "1H Direction",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 1, h1_direction,
               text_color = h1_direction == "bull" ? color.lime : color.red,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 2, "1H Valid",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 2, str.tostring(h1_trend_valid),
               text_color = h1_trend_valid ? color.lime : color.red,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 3, "15M ADX",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 3, str.tostring(m15_adx, "#.#"),
               text_color = color.yellow,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 4, "15M ADX drop",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 4, str.tostring(adx_drop_val, "#.#"),
               text_color = color.yellow,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 5, "15M ATR mult",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 5, str.tostring(atr_mult_val, "#.##") + "x",
               text_color = color.yellow,
               bgcolor    = color.new(color.black, 70))

    table.cell(t, 0, 6, "REGIME",
               text_color = color.white,
               bgcolor    = color.new(color.black, 70))
    table.cell(t, 1, 6, regime,
               text_color = regime_col,
               bgcolor    = color.new(color.black, 70))
