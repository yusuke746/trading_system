//@version=6
indicator("SMC Core [CHoCH/FVG/Zone]", overlay=true, max_labels_count=500, max_boxes_count=500, max_lines_count=500)

// ─── Parameters ───────────────────────────────────────────────────────────────
swing_length      = input.int(5,    "スイング検出バー数",      minval=2,  maxval=10)
fvg_atr_min_mult  = input.float(0.3,"FVG最小サイズ(ATR倍率)",  minval=0.1, maxval=1.0, step=0.1)
fvg_show          = input.bool(true, "FVG表示")
zone_impulse_bars = input.int(10,   "インパルス判定バー数",     minval=3,  maxval=30)
zone_impulse_mult = input.float(2.0,"インパルス判定ATR倍率",    minval=0.5, maxval=5.0, step=0.1)
zone_show         = input.bool(true, "Zone表示")
atr_period        = input.int(14,   "ATR期間",                 minval=5,  maxval=30)
show_debug        = input.bool(true, "デバッグ情報表示")

// ─── ATR（全体で共有） ─────────────────────────────────────────────────────────
atr = ta.atr(atr_period)

// ═══════════════════════════════════════════════════════════════════════════════
// ① CHoCH（Change of Character）
// ═══════════════════════════════════════════════════════════════════════════════
// ta.pivothigh/ta.pivotlow はswing_length本前に確定する（遅延は仕様通り）
swing_high = ta.pivothigh(high, swing_length, swing_length)
swing_low  = ta.pivotlow(low,  swing_length, swing_length)

var float last_swing_high = na
var float last_swing_low  = na

if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low

// close確定のみ：クロスした瞬間だけ検出（ずっと超えている間は発火しない）
bullish_choch = not na(last_swing_high) and close > last_swing_high and close[1] <= last_swing_high
bearish_choch = not na(last_swing_low)  and close < last_swing_low  and close[1] >= last_swing_low

if bullish_choch
    label.new(bar_index, low - atr * 0.5, "CHoCH↑", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)
    last_swing_high := na  // 次のスイング高値確定まで再発火しない
if bearish_choch
    label.new(bar_index, high + atr * 0.5, "CHoCH↓", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)
    last_swing_low := na   // 次のスイング安値確定まで再発火しない

// ═══════════════════════════════════════════════════════════════════════════════
// ② FVG（Fair Value Gap）
// ═══════════════════════════════════════════════════════════════════════════════
fvg_min_size = atr * fvg_atr_min_mult

var array<box>   bull_fvg_boxes = array.new<box>()
var array<float> bull_fvg_mid   = array.new<float>()   // 50%ライン
var array<box>   bear_fvg_boxes = array.new<box>()
var array<float> bear_fvg_mid   = array.new<float>()   // 50%ライン

// 強気FVG：candle[2].high < candle[0].low（2本前高値と現在安値の間にギャップ）
bull_fvg_exists = high[2] < low[0] and (low[0] - high[2]) >= fvg_min_size
// 弱気FVG：candle[2].low > candle[0].high（2本前安値と現在高値の間にギャップ）
bear_fvg_exists = low[2] > high[0] and (low[2] - high[0]) >= fvg_min_size

if fvg_show and bull_fvg_exists
    b = box.new(bar_index - 2, low[0], bar_index + 50, high[2], border_color=color.new(color.green, 70), bgcolor=color.new(color.green, 80))
    array.push(bull_fvg_boxes, b)
    array.push(bull_fvg_mid,   (low[0] + high[2]) / 2.0)

if fvg_show and bear_fvg_exists
    b = box.new(bar_index - 2, low[2], bar_index + 50, high[0], border_color=color.new(color.red, 70), bgcolor=color.new(color.red, 80))
    array.push(bear_fvg_boxes, b)
    array.push(bear_fvg_mid,   (low[2] + high[0]) / 2.0)

// 強気FVG：更新 or 無効化（close <= mid で50%以上埋まり → 削除）
int _bfi = array.size(bull_fvg_boxes) - 1
while _bfi >= 0
    b   = array.get(bull_fvg_boxes, _bfi)
    mid = array.get(bull_fvg_mid,   _bfi)
    if close <= mid
        box.delete(b)
        array.remove(bull_fvg_boxes, _bfi)
        array.remove(bull_fvg_mid,   _bfi)
    else
        box.set_right(b, bar_index + 50)
    _bfi -= 1

// 弱気FVG：更新 or 無効化（close >= mid で50%以上埋まり → 削除）
int _bbi = array.size(bear_fvg_boxes) - 1
while _bbi >= 0
    b   = array.get(bear_fvg_boxes, _bbi)
    mid = array.get(bear_fvg_mid,   _bbi)
    if close >= mid
        box.delete(b)
        array.remove(bear_fvg_boxes, _bbi)
        array.remove(bear_fvg_mid,   _bbi)
    else
        box.set_right(b, bar_index + 50)
    _bbi -= 1

// ═══════════════════════════════════════════════════════════════════════════════
// ③ Zone（需給ゾーン）
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Zone候補（単一変数で最新1本のみ保持） ────────────────────────────────────
// 陰線/陽線が来るたびに上書きされるため、常に最新の候補1本のみが有効
var int   dem_cand_bar  = na
var float dem_cand_low  = na
var float dem_cand_high = na
var float dem_cand_atr  = na   // 候補バー時点のATRを固定保存

var int   sup_cand_bar  = na
var float sup_cand_low  = na
var float sup_cand_high = na
var float sup_cand_atr  = na   // 候補バー時点のATRを固定保存

// ─── 確定済みZone管理配列 ──────────────────────────────────────────────────────
var array<box>   dem_boxes  = array.new<box>()
var array<float> dem_lows   = array.new<float>()      // 無効化判定用（zone底）
var array<label> dem_labels = array.new<label>()

var array<box>   sup_boxes  = array.new<box>()
var array<float> sup_highs  = array.new<float>()      // 無効化判定用（zone天井）
var array<label> sup_labels = array.new<label>()

bool is_bearish = close < open
bool is_bullish = close > open

// 陰線 → 需要ゾーン候補を上書き（前の候補は自動的に破棄される）
if is_bearish
    dem_cand_bar  := bar_index
    dem_cand_low  := low
    dem_cand_high := high
    dem_cand_atr  := atr

// 陽線 → 供給ゾーン候補を上書き（前の候補は自動的に破棄される）
if is_bullish
    sup_cand_bar  := bar_index
    sup_cand_low  := low
    sup_cand_high := high
    sup_cand_atr  := atr

// ─── 需要ゾーン候補を処理 ──────────────────────────────────────────────────────
// 候補バーのlowから現在highまでの上昇が zone_impulse_mult × 候補ATR 以上 → 確定
if not na(dem_cand_bar)
    if bar_index - dem_cand_bar > zone_impulse_bars
        // ①タイムアウト → 候補破棄
        dem_cand_bar := na
    else if (high - dem_cand_low) >= dem_cand_atr * zone_impulse_mult
        // 上昇インパルス確認 → 需要ゾーン確定
        if zone_show
            b   = box.new(dem_cand_bar, dem_cand_high, bar_index, dem_cand_low, border_color=color.new(color.blue, 70), bgcolor=color.new(color.blue, 85))
            lbl = label.new(dem_cand_bar, dem_cand_low, "D", color=color.new(color.blue, 50), textcolor=color.white, style=label.style_label_up, size=size.small)
            array.push(dem_boxes,  b)
            array.push(dem_lows,   dem_cand_low)
            array.push(dem_labels, lbl)
        // ②確定後 → 候補リセット（重複確定を防ぐ）
        dem_cand_bar := na

// ─── 供給ゾーン候補を処理 ──────────────────────────────────────────────────────
// 候補バーのhighから現在lowまでの下落が zone_impulse_mult × 候補ATR 以上 → 確定
if not na(sup_cand_bar)
    if bar_index - sup_cand_bar > zone_impulse_bars
        // ①タイムアウト → 候補破棄
        sup_cand_bar := na
    else if (sup_cand_high - low) >= sup_cand_atr * zone_impulse_mult
        // 下落インパルス確認 → 供給ゾーン確定
        if zone_show
            b   = box.new(sup_cand_bar, sup_cand_high, bar_index, sup_cand_low, border_color=color.new(color.orange, 70), bgcolor=color.new(color.orange, 85))
            lbl = label.new(sup_cand_bar, sup_cand_high, "S", color=color.new(color.orange, 50), textcolor=color.white, style=label.style_label_down, size=size.small)
            array.push(sup_boxes,  b)
            array.push(sup_highs,  sup_cand_high)
            array.push(sup_labels, lbl)
        // ②確定後 → 候補リセット（重複確定を防ぐ）
        sup_cand_bar := na

// ─── 確定済み需要ゾーン：右端延長 & 無効化チェック ────────────────────────────
// 無効化：zone底をclose確定で下抜けたとき（ヒゲ抜けでは無効化しない）
int _dbi = array.size(dem_boxes) - 1
while _dbi >= 0
    b        = array.get(dem_boxes,  _dbi)
    zone_low = array.get(dem_lows,   _dbi)
    lbl      = array.get(dem_labels, _dbi)
    if close < zone_low
        box.delete(b)
        label.delete(lbl)
        array.remove(dem_boxes,  _dbi)
        array.remove(dem_lows,   _dbi)
        array.remove(dem_labels, _dbi)
    else
        box.set_right(b, bar_index)
    _dbi -= 1

// ─── 確定済み供給ゾーン：右端延長 & 無効化チェック ────────────────────────────
// 無効化：zone天井をclose確定で上抜けたとき（ヒゲ抜けでは無効化しない）
int _sbi = array.size(sup_boxes) - 1
while _sbi >= 0
    b         = array.get(sup_boxes,  _sbi)
    zone_high = array.get(sup_highs,  _sbi)
    lbl       = array.get(sup_labels, _sbi)
    if close > zone_high
        box.delete(b)
        label.delete(lbl)
        array.remove(sup_boxes,  _sbi)
        array.remove(sup_highs,  _sbi)
        array.remove(sup_labels, _sbi)
    else
        box.set_right(b, bar_index)
    _sbi -= 1

// ═══════════════════════════════════════════════════════════════════════════════
// デバッグテーブル
// ═══════════════════════════════════════════════════════════════════════════════
if show_debug
    var table t = table.new(position.bottom_right, 2, 7, bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1, frame_color=color.gray, frame_width=1)
    int active_fvgs  = array.size(bull_fvg_boxes) + array.size(bear_fvg_boxes)
    int active_zones = array.size(dem_boxes)       + array.size(sup_boxes)
    table.cell(t, 0, 0, "Last Swing High", text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 0, na(last_swing_high) ? "n/a" : str.tostring(last_swing_high, "#.##"), text_color=color.yellow, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 1, "Last Swing Low",  text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 1, na(last_swing_low)  ? "n/a" : str.tostring(last_swing_low,  "#.##"), text_color=color.yellow, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 2, "Bull CHoCH",      text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 2, str.tostring(bullish_choch), text_color=bullish_choch ? color.lime : color.gray, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 3, "Bear CHoCH",      text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 3, str.tostring(bearish_choch), text_color=bearish_choch ? color.red  : color.gray, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 4, "ATR",             text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 4, str.tostring(atr, "#.##"), text_color=color.yellow, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 5, "Active FVGs",     text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 5, str.tostring(active_fvgs),  text_color=color.yellow, bgcolor=color.new(color.black, 70))
    table.cell(t, 0, 6, "Active Zones",    text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(t, 1, 6, str.tostring(active_zones), text_color=color.yellow, bgcolor=color.new(color.black, 70))
